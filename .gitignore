# Terraform working directory
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Terraform plan files
*.tfplan

# Terraform variable files that may contain secrets
*.tfvars
*.tfvars.json

# Terraform crash logs
crash.log
crash.*.log

# SSH private keys
*.pem
*.key
ansible/aws-infra-key

# Ansible temporary files
*.retry

# Operating system files
.DS_Store
Thumbs.db

# VS Code local settings
.vscode/

